{
  "name": "desafioscteciaparadevs",
  "version": "1.0.0",
  "description": "Full-stack web application with CRUD operations for business management",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "docker:check": "bash scripts/check-docker.sh",
    "docker:fix-permissions": "bash scripts/fix-docker-permissions.sh",
    "mongodb:start": "bash scripts/docker-compose-wrapper.sh -f docker-compose.dev.yml up -d",
    "mongodb:start:direct": "bash scripts/start-mongodb-direct.sh",
    "mongodb:stop": "bash scripts/docker-compose-wrapper.sh -f docker-compose.dev.yml down",
    "mongodb:stop:direct": "bash scripts/stop-mongodb-direct.sh",
    "mongodb:logs": "docker logs desafio-mongodb",
    "mongodb:shell": "docker exec -it desafio-mongodb mongosh",
    "mongodb:status": "docker ps | grep desafio-mongodb || echo 'MongoDB não está rodando'",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:full": "npm run mongodb:start && sleep 3 && npm run dev",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "build": "npm run build:backend && npm run build:frontend",
    "test:backend": "cd backend && npm test",
    "test:frontend": "cd frontend && npm test",
    "test": "npm run test:backend && npm run test:frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
